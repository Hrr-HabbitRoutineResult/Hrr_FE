<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 포커스 되었을 때 -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/> <!-- 배경 색상 -->
            <stroke
                android:width="1dp"
                android:color="#FCA849"/> <!-- 포커스 시 테두리 색상 -->
            <corners android:radius="10dp"/>
        </shape>
    </item>

    <!-- 기본 상태 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/> <!-- 배경 색상 -->
            <stroke
                android:width="1dp"
                android:color="#E6E7E8"/> <!-- 기본 테두리 색상 -->
            <corners android:radius="10dp"/>
        </shape>
    </item>

</selector>
