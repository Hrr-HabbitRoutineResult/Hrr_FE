<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/layout_make_challenge_header"
        android:id="@+id/layout_make_challenge_calendar_header"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_make_challenge_calendar_header"
        app:layout_constraintBottom_toTopOf="@id/ll_make_challenge_calendar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:weightSum="1">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="시작일"
                android:fontFamily="@font/noto_sans_kr_semi_bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:includeFontPadding="false"/>

            <com.example.hrr_android.challenge.ui.record.progress.calendar.CustomCalendarView
                android:id="@+id/view_make_challenge_calendar1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="종료일"
                android:fontFamily="@font/noto_sans_kr_semi_bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:includeFontPadding="false"/>

            <com.example.hrr_android.challenge.ui.record.progress.calendar.CustomCalendarView
                android:id="@+id/view_make_challenge_calendar2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp" />

        </LinearLayout>

    </ScrollView>


    <!-- 완료 버튼 -->
    <LinearLayout
        android:id="@+id/ll_make_challenge_calendar"
        android:layout_width="match_parent"
        android:layout_height="79dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="vertical"
        android:background="@color/white">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line" />

        <FrameLayout
            android:id="@+id/btn_make_basic_challenge"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="13dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/bg_button_activate_deactivate" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/noto_sans_kr_medium"
                android:gravity="center"
                android:text="개설하기"
                android:textColor="@color/text_tertiary"
                android:textSize="16sp"
                android:includeFontPadding="false"/>
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>