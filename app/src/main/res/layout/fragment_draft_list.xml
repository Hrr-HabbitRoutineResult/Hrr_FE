<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".challenge.certification.ui.draft.DraftListFragment">

    <!-- 상단 헤더 영역 -->
    <include
        android:id="@+id/layout_record_header"
        layout="@layout/layout_record_header" />

    <!-- 임시저장된 글 개수 영역 -->
    <TextView
        android:id="@+id/tv_draft_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="총 3개"
        android:textSize="15sp"
        android:fontFamily="@font/font_style"
        android:textFontWeight="400"
        android:textColor="@color/grey_500"
        android:includeFontPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_record_header"/>

    <!-- 편집 버튼 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_draft_edit"
        android:layout_width="54dp"
        android:layout_height="25dp"
        android:layout_marginEnd="16dp"
        android:text="편집"
        android:textSize="13sp"
        android:fontFamily="@font/font_style"
        android:textFontWeight="500"
        android:textColor="@color/text_tertiary"
        android:includeFontPadding="false"
        android:background="@drawable/bg_button_grey_line"
        android:stateListAnimator="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_draft_count"
        app:layout_constraintBottom_toBottomOf="@id/tv_draft_count"/>

    <!-- 임시저장 글 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_drafts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="11dp"
        app:layout_constraintTop_toBottomOf="@id/tv_draft_count"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- 편집 모드 버튼 영역 (기본값은 gone) -->
    <LinearLayout
        android:id="@+id/ll_edit_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="61dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_delete_all"
            android:layout_width="160dp"
            android:layout_height="45dp"
            android:text="전체 삭제"
            android:textSize="16sp"
            android:fontFamily="@font/font_style"
            android:textFontWeight="600"
            android:textColor="@color/text_tertiary"
            android:includeFontPadding="false"
            android:background="@drawable/bg_button_like"
            android:stateListAnimator="@null" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_delete_selected"
            android:layout_width="160dp"
            android:layout_height="45dp"
            android:layout_marginStart="8dp"
            android:text="선택 삭제"
            android:textSize="16sp"
            android:fontFamily="@font/font_style"
            android:textFontWeight="600"
            android:textColor="@color/white"
            android:includeFontPadding="false"
            android:background="@drawable/btn_navy"
            android:stateListAnimator="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>