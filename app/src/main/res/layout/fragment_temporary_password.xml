<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="55dp">

    <TextView
        android:id="@+id/tv_temporary_password_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/noto_sans_kr_bold"
        android:includeFontPadding="false"
        android:text="임시비밀번호가 발급되었어요"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_verification_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/noto_sans_kr_regular"
        android:includeFontPadding="false"
        android:text="임시비밀번호는 로그인 후 내 정보 수정에서\n비밀번호를 변경해주세요."
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_temporary_password_title" />

    <ImageView
        android:id="@+id/iv_temporary_password_background"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="70dp"
        android:background="@drawable/bg_square_grey_10"
        app:layout_constraintTop_toBottomOf="@+id/tv_verification_description"
        tools:layout_editor_absoluteX="16dp" />

    <TextView
        android:id="@+id/tv_temporary_password_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/noto_sans_kr_medium"
        android:includeFontPadding="false"
        android:text="임시비밀번호 : "
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:layout_marginStart="20dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_temporary_password_background"
        app:layout_constraintStart_toStartOf="@+id/iv_temporary_password_background"
        app:layout_constraintTop_toTopOf="@+id/iv_temporary_password_background" />

    <TextView
        android:id="@+id/tv_temporary_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/noto_sans_kr_medium"
        android:includeFontPadding="false"
        android:text="5678@!!23"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_temporary_password_background"
        app:layout_constraintStart_toEndOf="@+id/tv_temporary_password_label"
        app:layout_constraintTop_toTopOf="@+id/iv_temporary_password_background" />

    <FrameLayout
        android:id="@+id/btn_verification_copy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/iv_temporary_password_background"
        app:layout_constraintBottom_toBottomOf="@id/iv_temporary_password_background"
        app:layout_constraintEnd_toEndOf="@id/iv_temporary_password_background">

        <!-- 배경 이미지 -->
        <ImageView
            android:id="@+id/iv_temporary_password_copy"
            android:layout_width="70dp"
            android:layout_height="30dp"
            android:src="@drawable/bg_button_deactivate_filled_30"
            android:layout_gravity="center"/>

        <!-- 버튼 텍스트 -->
        <TextView
            android:id="@+id/tv_temporary_password_copy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="복사하기"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:layout_gravity="center"/>
    </FrameLayout>

    <!-- 선 (구분선) -->
    <View
        android:id="@+id/line_temporary_password"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="14dp"
        android:background="@color/text_line"
        app:layout_constraintBottom_toTopOf="@id/btn_temporary_password_next"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 다음 버튼 -->
    <FrameLayout
        android:id="@+id/btn_temporary_password_next"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 배경 이미지 -->
        <ImageView
            android:id="@+id/iv_temporary_password_next"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/btn_navy" />

        <!-- 버튼 텍스트 -->
        <TextView
            android:id="@+id/tv_temporary_password_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="로그인으로 가기"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:layout_gravity="center"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
