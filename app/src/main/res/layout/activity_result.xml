<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#F7F7F7"
    tools:context=".onboarding.ui.ResultActivity">

    <!-- 배경 이미지 -->
    <ImageView
        android:id="@+id/iv_result_background"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:scaleType="fitXY"
        android:src="@drawable/bg_onboarding_intro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 로고 -->
    <ImageView
        android:id="@+id/iv_result_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_app_logo_color"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="55dp"
        android:layout_marginStart="22dp" />

    <!-- 텍스트 -->
    <TextView
        android:id="@+id/tv_result_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="85dp"
        android:text="이런 챌린지는 어떠세요?"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:fontFamily="@font/noto_sans_kr_bold"
        android:includeFontPadding="false"
        app:layout_constraintStart_toStartOf="@+id/iv_result_logo"
        app:layout_constraintTop_toBottomOf="@id/iv_result_logo" />

    <TextView
        android:id="@+id/tv_result_describe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="사용자 님에게 잘 어울리는 챌린지를 가져왔어요."
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        android:textColor="@color/white"
        app:layout_constraintStart_toStartOf="@+id/tv_result_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_result_title" />

    <!-- 뷰 페이저 추가 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_onboarding_challenge"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:clipToPadding="false"
        android:layout_marginTop="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_result_describe" />

    <ImageView
        android:id="@+id/btn_result_reset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/btn_result_reset"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@+id/layout_result_bottom"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 하단 레이아웃 -->
    <LinearLayout
        android:id="@+id/layout_result_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 회색 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="14dp"
            android:background="@color/text_line" />

        <!-- 다음 버튼 -->
        <FrameLayout
            android:id="@+id/btn_result_to_home"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 배경 이미지 -->
            <ImageView
                android:id="@+id/iv_result_to_home"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/btn_navy" />

            <!-- 버튼 텍스트 -->
            <TextView
                android:id="@+id/tv_result_to_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="홈화면으로 가기"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:fontFamily="@font/noto_sans_kr_semi_bold"
                android:layout_gravity="center"/>
        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
