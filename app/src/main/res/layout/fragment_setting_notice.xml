<?xml version="1.0" encoding="utf-8"?>
<ScrollView
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="match_parent"
tools:context=".SettingNoticeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="35dp"
        android:paddingStart="24dp"
        android:paddingEnd="25dp"
        android:paddingBottom="96dp">

        <!--   푸시 알림 헤더     -->
        <LinearLayout
            android:id="@+id/ll_setting_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="6dp">

        <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="푸시 알림"
                android:fontFamily="@font/font_style"
                android:textFontWeight="600"
                android:includeFontPadding="false"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:layout_weight="1"/>

        </LinearLayout>

        <!--   전체 알림 일시 중단     -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingVertical="20dp">

        <TextView
                android:id="@+id/tv_all_notice_pause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전체 일시 중단"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="알림 수신이 일시 중단됩니다"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@+id/tv_all_notice_pause"
                android:layout_marginTop="6dp"
                app:layout_constraintStart_toStartOf="parent"/>

        <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_all_notice_stop"
                android:layout_width="50dp"
                android:layout_height="25dp"
                android:layout_gravity="center_vertical"
                style="@style/custom_toggle"
                android:padding="3dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"/>

        <!--   챌린지 및 인증 알림     -->
        <LinearLayout
            android:id="@+id/ll_setting_post_comment"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:paddingVertical="19dp"
            android:paddingHorizontal="4.5dp">

        <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="챌린지 및 인증"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_weight="1"/>

        <ImageView
                android:layout_width="6dp"
                android:layout_height="12dp"
                android:src="@drawable/btn_setting_more"
                app:tint="@color/text_tertiary"
                android:layout_gravity="end|center_vertical"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"/>


        <!--   게시글에 대한 댓글 알림     -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingVertical="20dp">

        <TextView
                android:id="@+id/tv_comment_for_post"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="게시글에 대한 댓글"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내 게시글에 댓글이 달렸을 때 알려드립니다"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@+id/tv_comment_for_post"
                android:layout_marginTop="6dp"
                app:layout_constraintStart_toStartOf="parent"/>

        <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_comment_for_post"
                android:layout_width="50dp"
                android:layout_height="25dp"
                android:layout_gravity="center_vertical"
                style="@style/custom_toggle"
                android:padding="3dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"/>

        <!--   쪽지 알림     -->
        <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingVertical="20dp">

            <TextView
                    android:id="@+id/tv_notice_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="쪽지"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="500"
                    android:includeFontPadding="false"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="새로운 쪽지를 받았을 때 알려드립니다"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="400"
                    android:includeFontPadding="false"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    app:layout_constraintTop_toBottomOf="@+id/tv_notice_message"
                    android:layout_marginTop="6dp"
                    app:layout_constraintStart_toStartOf="parent"/>

            <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_new_messsage"
                    android:layout_width="50dp"
                    android:layout_height="25dp"
                    android:layout_gravity="center_vertical"
                    style="@style/custom_toggle"
                    android:padding="3dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text_line"/>

        <!--   뱃지 알림     -->
        <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingVertical="20dp">

            <TextView
                    android:id="@+id/tv_notice_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="뱃지"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="500"
                    android:includeFontPadding="false"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="새로운 뱃지를 획득했을 때 알려드립니다"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="400"
                    android:includeFontPadding="false"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    app:layout_constraintTop_toBottomOf="@+id/tv_notice_badge"
                    android:layout_marginTop="6dp"
                    app:layout_constraintStart_toStartOf="parent"/>

            <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_new_badge"
                    android:layout_width="50dp"
                    android:layout_height="25dp"
                    android:layout_gravity="center_vertical"
                    style="@style/custom_toggle"
                    android:padding="3dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text_line"/>

        <!--   팔로워 알림     -->
        <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingVertical="20dp">

            <TextView
                    android:id="@+id/tv_notice_follower"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="팔로워"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="500"
                    android:includeFontPadding="false"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="나를 팔로우한 새로운 챌린저가 있을 때 알려드립니다"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="400"
                    android:includeFontPadding="false"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    app:layout_constraintTop_toBottomOf="@+id/tv_notice_follower"
                    android:layout_marginTop="6dp"
                    app:layout_constraintStart_toStartOf="parent"/>

            <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_new_follower"
                    android:layout_width="50dp"
                    android:layout_height="25dp"
                    android:layout_gravity="center_vertical"
                    style="@style/custom_toggle"
                    android:padding="3dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text_line"/>

    </LinearLayout>

</ScrollView>
