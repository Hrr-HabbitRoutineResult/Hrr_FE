<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ProfileBadgeFragment">

    <!-- 뱃지 화면 제목 -->
    <LinearLayout
        android:id="@+id/ll_profile_badge_title"
        android:layout_width="wrap_content"
        android:layout_height="29dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="16dp">

        <TextView
            android:id="@+id/tv_profile_badge_title"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="마이 뱃지"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/font_style"
            android:textFontWeight="600"
            android:includeFontPadding="false"
            android:textSize="18sp"
            android:layout_marginTop="-2dp"
            android:layout_marginEnd="208dp"/>

        <!-- 뱃지 더보기 -->
        <LinearLayout
            android:id="@+id/ll_profile_badge_more"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:layout_marginTop="-9dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="38dp"
                android:layout_height="19dp"
                android:text="더보기"
                android:textColor="@color/text_tertiary"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="4dp"
                android:layout_marginEnd="7dp"/>

            <ImageView
                android:layout_width="5dp"
                android:layout_height="20dp"
                android:src="@drawable/btn_arrow_right"
                app:tint="@color/text_tertiary"
                android:tintMode="src_in"
                android:scaleType="centerCrop"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- 획득한 뱃지 없을 때 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_profile_badge_content_no"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/ll_profile_badge_title"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:visibility="visible"
        android:paddingBottom="79dp">

        <ImageView
            android:id="@+id/iv_profile_badge_default_bg"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/profile_challenge_default_bg"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iv_profile_badge_no"
            android:layout_width="50dp"
            android:layout_height="63.11dp"
            android:src="@drawable/ic_profile_no_data"
            app:layout_constraintTop_toTopOf="@+id/iv_profile_badge_default_bg"
            app:layout_constraintStart_toStartOf="@+id/iv_profile_badge_default_bg"
            app:layout_constraintEnd_toEndOf="@+id/iv_profile_badge_default_bg"
            app:layout_constraintBottom_toBottomOf="@id/iv_profile_badge_default_bg"
            android:layout_marginTop="58.95dp"
            android:layout_marginBottom="77.95dp"
            android:layout_marginStart="139dp"
            android:layout_marginEnd="139dp"/>

        <TextView
            android:id="@+id/tv_profile_badge_no"
            android:layout_width="wrap_content"
            android:layout_height="19dp"
            android:text="아직 획득한 뱃지가 없어요"
            android:textSize="13sp"
            android:fontFamily="@font/font_style"
            android:textFontWeight="400"
            android:includeFontPadding="false"
            app:layout_constraintTop_toBottomOf="@+id/iv_profile_badge_no"
            app:layout_constraintStart_toStartOf="@+id/iv_profile_badge_default_bg"
            app:layout_constraintEnd_toEndOf="@+id/iv_profile_badge_default_bg"
            android:layout_marginTop="1dp"
            android:layout_marginStart="108.5dp"
            android:layout_marginEnd="108.55dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 획득한 뱃지 있을 경우 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_profile_badge_my"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/ll_profile_badge_title"
        android:layout_marginTop="21dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone"
        android:paddingBottom="70dp">

        <TextView
            android:id="@+id/tv_profile_badge_content_type"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text="유형"
            android:fontFamily="@font/font_style"
            android:textFontWeight="500"
            android:includeFontPadding="false"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:paddingHorizontal="16dp"/>

        <!-- 유형 뱃지 없을 때 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_profile_badge_type_no"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/tv_profile_badge_content_type"
            android:layout_marginTop="15dp"
            app:layout_constraintBottom_toTopOf="@+id/tv_profile_badge_content_category"
            android:layout_marginBottom="43dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="visible"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/iv_profile_challenge_default_bg"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:src="@drawable/profile_challenge_default_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <ImageView
                android:id="@+id/iv_profile_participatingChallenge_no"
                android:layout_width="50dp"
                android:layout_height="63.11dp"
                android:src="@drawable/ic_profile_no_data"
                app:layout_constraintTop_toTopOf="@+id/iv_profile_challenge_default_bg"
                app:layout_constraintStart_toStartOf="@+id/iv_profile_challenge_default_bg"
                app:layout_constraintEnd_toEndOf="@+id/iv_profile_challenge_default_bg"
                app:layout_constraintBottom_toBottomOf="@id/iv_profile_challenge_default_bg"
                android:layout_marginTop="18.95dp"
                android:layout_marginBottom="37.95dp"
                android:layout_marginStart="139dp"
                android:layout_marginEnd="139dp"/>

            <TextView
                android:id="@+id/tv_profile_participatingChallenge_no"
                android:layout_width="wrap_content"
                android:layout_height="19dp"
                android:text="아직 획득한 뱃지가 없어요"
                android:textSize="13sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                app:layout_constraintTop_toBottomOf="@+id/iv_profile_participatingChallenge_no"
                app:layout_constraintStart_toStartOf="@+id/iv_profile_challenge_default_bg"
                app:layout_constraintEnd_toEndOf="@+id/iv_profile_challenge_default_bg"
                android:layout_marginTop="1dp"
                android:layout_marginStart="97dp"
                android:layout_marginEnd="97dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 유형 뱃지 있을 때 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_profile_badge_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/tv_profile_badge_content_type"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toStartOf="parent"
            android:paddingHorizontal="18dp"
            app:layout_constraintBottom_toTopOf="@+id/tv_profile_badge_content_category"
            tools:listitem="@layout/item_profile_badge"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_profile_badge_content_category"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text="카테고리"
            android:fontFamily="@font/font_style"
            android:textFontWeight="500"
            android:includeFontPadding="false"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@+id/rv_profile_badge_type"
            android:layout_marginTop="45dp"
            app:layout_constraintStart_toStartOf="parent"
            android:paddingHorizontal="16dp"/>

        <!-- 카테고리 뱃지 없을 때 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_profile_badge_category_no"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/tv_profile_badge_content_category"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="visible"
            android:paddingBottom="54dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/iv_profile_completedChallenge_default_bg"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:src="@drawable/profile_challenge_default_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <ImageView
                android:id="@+id/iv_profile_completedChallenge_no"
                android:layout_width="50dp"
                android:layout_height="63.11dp"
                android:src="@drawable/ic_profile_no_data"
                app:layout_constraintTop_toTopOf="@+id/iv_profile_completedChallenge_default_bg"
                app:layout_constraintStart_toStartOf="@+id/iv_profile_completedChallenge_default_bg"
                app:layout_constraintEnd_toEndOf="@+id/iv_profile_completedChallenge_default_bg"
                app:layout_constraintBottom_toBottomOf="@id/iv_profile_completedChallenge_default_bg"
                android:layout_marginTop="18.95dp"
                android:layout_marginBottom="37.95dp"
                android:layout_marginStart="139dp"
                android:layout_marginEnd="139dp"/>

            <TextView
                android:id="@+id/tv_profile_completedChallenge_no"
                android:layout_width="wrap_content"
                android:layout_height="19dp"
                android:text="아직 획득한 뱃지가 없어요"
                android:textSize="13sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                app:layout_constraintTop_toBottomOf="@+id/iv_profile_completedChallenge_no"
                app:layout_constraintStart_toStartOf="@+id/iv_profile_completedChallenge_default_bg"
                app:layout_constraintEnd_toEndOf="@+id/iv_profile_completedChallenge_default_bg"
                android:layout_marginTop="1dp"
                android:layout_marginStart="97dp"
                android:layout_marginEnd="97dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 카테고리 뱃지 있을 때 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_profile_badge_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/tv_profile_badge_content_category"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toStartOf="parent"
            android:paddingHorizontal="18dp"
            tools:listitem="@layout/item_profile_badge"
            android:clipToPadding="false"
            android:visibility="gone"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>