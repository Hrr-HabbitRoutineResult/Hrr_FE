<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MakeChallengeFragment"
    android:background="@color/white">

    <include layout="@layout/layout_make_challenge_header" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:weightSum="1"
        android:layout_marginTop="85dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:layout_marginTop="50dp"
            android:layout_weight="1"
            android:fontFamily="@font/noto_sans_kr_bold"
            android:text="어떤 챌린지를 만들고 싶으신가요?"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:includeFontPadding="false"/>

        <!-- 카테고리 제목 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="65dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans_kr_semi_bold"
                android:text="카테고리"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:includeFontPadding="false"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans_kr_semi_bold"
                android:text=" *"
                android:textColor="@color/sub_01"
                android:textSize="16sp"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- 카테고리 버튼 -->
        <LinearLayout
            android:id="@+id/ll_choose_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:weightSum="3">

                <FrameLayout
                    android:id="@+id/btn_choose_category_exercise"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_challenge_filter"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:font="@font/noto_sans_kr_medium"
                        android:gravity="center"
                        android:text="학업"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btn_choose_category_study"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_challenge_filter"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:font="@font/noto_sans_kr_medium"
                        android:gravity="center"
                        android:text="운동"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btn_choose_category_employment"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_challenge_filter"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:font="@font/noto_sans_kr_medium"
                        android:gravity="center"
                        android:text="취업준비"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="3">

                <FrameLayout
                    android:id="@+id/btn_choose_category_habit"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_challenge_filter"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:font="@font/noto_sans_kr_medium"
                        android:gravity="center"
                        android:text="생활습관"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btn_choose_category_hobby"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_challenge_filter"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:font="@font/noto_sans_kr_medium"
                        android:gravity="center"
                        android:text="취미"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 유형 제목 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans_kr_semi_bold"
                android:text="유형"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:includeFontPadding="false"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans_kr_semi_bold"
                android:text=" *"
                android:textColor="@color/sub_01"
                android:textSize="16sp"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- 유형 버튼 -->
        <LinearLayout
            android:id="@+id/ll_choose_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <FrameLayout
                android:id="@+id/btn_choose_type_study"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/btn_challenge_filter_radius15"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:font="@font/noto_sans_kr_medium"
                    android:gravity="center"
                    android:text="베이직"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:font="@font/noto_sans_kr_regular"
                    android:gravity="start"
                    android:text="개인별로 자유롭게 인증을\n진행할 수 있습니다."
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btn_choose_type_basic"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:background="@drawable/btn_challenge_filter_radius15"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginStart="25dp"
                    android:layout_marginTop="25dp"
                    android:font="@font/noto_sans_kr_medium"
                    android:gravity="center"
                    android:text="스터디"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:font="@font/noto_sans_kr_regular"
                    android:gravity="start"
                    android:text="지정된 요일에 인증 후,\n스터디를 할 수 있습니다."
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="79dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@color/white">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line" />

        <FrameLayout
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="13dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/bg_button_activate_deactivate" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/noto_sans_kr_medium"
                android:gravity="center"
                android:text="다음"
                android:textColor="@color/text_tertiary"
                android:textSize="16sp" />
        </FrameLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>