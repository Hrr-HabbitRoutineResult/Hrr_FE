<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 체크박스 리스트를 포함한 LinearLayout -->
    <LinearLayout
        android:id="@+id/layout_checkboxes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="70dp"
        android:layout_marginBottom="16dp">

        <!-- 전체 동의 체크박스 -->
        <android.widget.CheckBox
            android:id="@+id/cb_all_agree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="전체 동의"
            android:textSize="15sp"
            android:button="@drawable/cb_custom"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:paddingStart="12dp"/>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"/>

        <!-- 약관 동의 체크박스 리스트 -->
        <android.widget.CheckBox
            android:id="@+id/cb_service_terms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="서비스 이용 약관 동의 (필수)"
            android:textSize="15sp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:button="@drawable/cb_custom"
            android:paddingStart="12dp"/>

        <android.widget.CheckBox
            android:id="@+id/cb_privacy_terms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="개인정보 수집 및 이용 동의 (필수)"
            android:textSize="15sp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:button="@drawable/cb_custom"
            android:layout_marginTop="20dp"
            android:paddingStart="12dp"/>



        <android.widget.CheckBox
            android:id="@+id/cb_third_party"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="개인정보 제3자 제공에 대한 안내 (선택)"
            android:textSize="15sp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:button="@drawable/cb_custom"
            android:layout_marginTop="20dp"
            android:paddingStart="12dp"/>

        <android.widget.CheckBox
            android:id="@+id/cb_marketing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="마케팅 및 광고성 정보 수신 동의 (선택)"
            android:textSize="15sp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:button="@drawable/cb_custom"
            android:layout_marginTop="20dp"
            android:paddingStart="12dp"/>
    </LinearLayout>

    <!-- 선 (구분선) -->
    <View
        android:id="@+id/line_terms"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="14dp"
        android:background="@color/text_line"
        app:layout_constraintBottom_toTopOf="@id/btn_terms_next"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 다음 버튼 -->
    <FrameLayout
        android:id="@+id/btn_terms_next"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 배경 이미지 -->
        <ImageView
            android:id="@+id/iv_terms_next"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/btn_navy" />

        <!-- 버튼 텍스트 -->
        <TextView
            android:id="@+id/tv_terms_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="다음"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:layout_gravity="center"/>
    </FrameLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
