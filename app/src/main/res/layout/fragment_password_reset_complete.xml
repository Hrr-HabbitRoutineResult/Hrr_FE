<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="55dp">

    <ImageView
        android:id="@+id/iv_reset_complete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:src="@drawable/img_reset_complete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="비밀번호가 변경되었습니다.\n변경된 비밀번호로 재로그인해주세요."
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/noto_sans_kr_semi_bold"
        android:includeFontPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_reset_complete" />

    <!-- 선 (구분선) -->
    <View
        android:id="@+id/line_reset_complete"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="14dp"
        android:background="@color/text_line"
        app:layout_constraintBottom_toTopOf="@id/btn_reset_complete_next"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 다음 버튼 -->
    <FrameLayout
        android:id="@+id/btn_reset_complete_next"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 배경 이미지 -->
        <ImageView
            android:id="@+id/iv_reset_complete_next"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/btn_navy" />

        <!-- 버튼 텍스트 -->
        <TextView
            android:id="@+id/tv_reset_complete_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="홈화면으로 가기"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:layout_gravity="center"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
