<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Fragment 띄울 뷰 -->
    <FrameLayout
        android:id="@+id/main_frame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/main_bottom_navi">

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"
            android:layout_gravity="bottom" />
    </FrameLayout>

    <!-- 네비게이션 바 -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/main_bottom_navi"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:itemIconSize="34dp"
        app:itemIconTint="@color/navi_item_color"
        app:itemTextColor="@color/navi_item_color"
        app:itemBackground="@android:color/transparent"
        android:background="@android:color/transparent"
        app:itemActiveIndicatorStyle="@style/Theme.Navi.Indicator"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_navi"
        app:itemPaddingTop="12dp"
        app:itemPaddingBottom="12dp"
        android:paddingHorizontal="26dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>