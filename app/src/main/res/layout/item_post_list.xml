<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/layout_post_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_item_post_list_community"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_grey_50_filled_30"
            android:paddingHorizontal="10dp"
            android:paddingVertical="2dp"
            android:layout_marginBottom="10dp"
            android:text="취업준비게시판"
            android:textSize="10sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:visibility="gone"/>

        <!-- 게시글 제목 -->
        <TextView
            android:id="@+id/tv_item_post_list_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/noto_sans_kr_medium"
            android:includeFontPadding="false"
            android:text="게시글 제목"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <!-- 게시글 내용 -->
        <TextView
            android:id="@+id/tv_item_post_list_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="게시글 내용"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- 시간 및 작성자 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_item_post_list_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_post_list_like"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="5dp"
                android:visibility="visible"/>

            <!-- 좋아요 텍스트 -->
            <TextView
                android:id="@+id/tv_item_post_list_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21"
                android:textColor="@color/sub_01"
                android:textSize="12sp"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"
                android:layout_marginEnd="10dp"
                android:visibility="visible"/>

            <ImageView
                android:id="@+id/iv_item_post_list_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_post_list_comment"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="5dp"
                android:visibility="visible"/>

            <!-- 댓글 텍스트 -->
            <TextView
                android:id="@+id/tv_item_post_list_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"
                android:visibility="visible"/>

            <!-- 구분자 -->
            <TextView
                android:id="@+id/tv_item_post_list_divider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="7dp"
                android:text="|"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"
                android:visibility="visible"/>

            <!-- 시간 텍스트 -->
            <TextView
                android:id="@+id/tv_item_post_list_created"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="02:24"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"/>

            <!-- 구분자 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="7dp"
                android:text="|"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"/>

            <!-- 작성자 텍스트 -->
            <TextView
                android:id="@+id/tv_item_post_list_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="익명"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 선 (구분선) -->
    <View
        android:id="@+id/line_community_header"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_line"
        app:layout_constraintTop_toBottomOf="@id/layout_post_list"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
