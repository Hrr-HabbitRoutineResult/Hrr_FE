<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 배경 이미지 -->
        <ImageView
            android:id="@+id/iv_home_background"
            android:layout_width="match_parent"
            android:layout_height="520dp"
            android:src="@drawable/bg_home_rounded"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 상단 로고 -->
        <ImageView
            android:id="@+id/iv_home_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_app_logo_color"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="55dp"
            android:layout_marginStart="22dp"/>

        <!-- 검색 아이콘 -->
        <ImageView
            android:id="@+id/iv_home_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:src="@drawable/ic_home_search"
            app:layout_constraintEnd_toStartOf="@id/iv_home_alarm"
            app:layout_constraintTop_toTopOf="@+id/iv_home_logo" />

        <!-- 알림 아이콘 -->
        <ImageView
            android:id="@+id/iv_home_alarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="25dp"
            android:src="@drawable/ic_home_alarm"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_home_search" />

        <!-- 타이틀 텍스트 -->
        <TextView
            android:id="@+id/tv_home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘도 챌린지를 해볼까요?"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:fontFamily="@font/noto_sans_kr_bold"
            android:includeFontPadding="false"
            app:layout_constraintTop_toBottomOf="@id/iv_home_logo"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="26dp"
            android:layout_marginStart="16dp"/>

        <!-- 서브 텍스트 -->
        <TextView
            android:id="@+id/tv_home_sub_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="안녕하세요, 김흐르 님! 챌린지에 참가해보세요."
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            app:layout_constraintTop_toBottomOf="@id/tv_home_title"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="5dp"
            android:layout_marginStart="16dp"/>

        <!-- 챌린지 참가 및 인증 프레임 레이아웃 -->
        <FrameLayout
            android:id="@+id/layout_home_challenge"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            app:layout_constraintTop_toBottomOf="@id/tv_home_sub_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:layout_marginTop="35dp">

            <include
                android:id="@+id/item_home_challenge_card_new"
                layout="@layout/item_challenge_card_new"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible"/>

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vp_home_challenge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:visibility="visible"/>
        </FrameLayout>

        <!-- 인디케이터 추가 -->
        <LinearLayout
            android:id="@+id/indicator_home_challenge_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="35dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@+id/iv_home_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 챌린지 보러가기 텍스트 -->
        <TextView
            android:id="@+id/tv_home_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="챌린지 보러가기"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:includeFontPadding="false"
            app:layout_constraintTop_toBottomOf="@id/iv_home_background"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="48dp"
            android:layout_marginStart="16dp"/>

        <!-- 가로 스크롤 가능한 RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_home_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:paddingStart="16dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/tv_home_category"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:orientation="horizontal"/>

        <!-- 이번 주 인기 챌린지 텍스트 -->
        <TextView
            android:id="@+id/tv_home_popular_challenge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="45dp"
            android:text="이번 주 인기 챌린지"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:includeFontPadding="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rv_home_category" />

        <FrameLayout
            android:id="@+id/layout_home_popular_challenge"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_home_popular_challenge">

            <!-- 그라데이션 배경 -->
            <ImageView
                android:id="@+id/iv_home_challenge_gradation"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:scaleType="fitXY"
                android:src="@drawable/bg_home_challenge_gradation"
                android:paddingStart="70dp"/>

            <!-- 배경 이미지 -->
            <ImageView
                android:id="@+id/iv_home_popular_challenge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_square_grey_10" />

            <!-- 챌린지 아이템 추가 -->
            <include
                android:id="@+id/item_home_challenge_summary"
                layout="@layout/item_challenge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </FrameLayout>

        <!-- 인기 글 텍스트 -->
        <TextView
            android:id="@+id/tv_home_popular_post"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="45dp"
            android:text="인기 글"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:includeFontPadding="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_home_popular_challenge" />

        <!-- 더보기 텍스트 -->
        <TextView
            android:id="@+id/tv_home_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:text="더 보기"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="@font/noto_sans_kr_medium"
            android:includeFontPadding="false"
            app:layout_constraintBottom_toBottomOf="@+id/iv_home_more"
            app:layout_constraintEnd_toEndOf="@id/iv_home_more"
            app:layout_constraintTop_toTopOf="@+id/iv_home_more" />

        <!-- 더보기 아이콘 -->
        <ImageView
            android:id="@+id/iv_home_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="45dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_home_more"
            app:layout_constraintBottom_toBottomOf="@+id/tv_home_popular_post"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_home_popular_challenge" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_home_hot_post"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_square_grey_15"
            android:paddingVertical="12dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="50dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_home_popular_post"/>

        <!-- 인기글 섹션 -->
        <FrameLayout
            android:id="@+id/layout_home_popular_post"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_home_popular_post"
            app:layout_constraintBottom_toBottomOf="parent"
            android:visibility="gone">

            <ImageView
                android:id="@+id/bg_home_hot_post_none"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_square_grey_filled_15" />

            <ImageView
                android:id="@+id/iv_home_hot_post_none"
                android:layout_width="wrap_content"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                android:layout_gravity="center"
                android:src="@drawable/img_character_grey" />

            <TextView
                android:id="@+id/tv_home_hot_post_none"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:text="고정된 게시판이 없어요"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:fontFamily="@font/noto_sans_kr_medium"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
