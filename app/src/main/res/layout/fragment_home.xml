<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    tools:context=".HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 배경 이미지 -->
        <ImageView
            android:id="@+id/iv_home_background"
            android:layout_width="match_parent"
            android:layout_height="490dp"
            android:src="@drawable/bg_home_rounded"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 상단 로고 -->
        <ImageView
            android:id="@+id/iv_home_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_app_logo_color"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="55dp"
            android:layout_marginStart="22dp"/>

        <!-- 검색 아이콘 -->
        <ImageView
            android:id="@+id/iv_home_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:src="@drawable/ic_home_search"
            app:layout_constraintEnd_toStartOf="@id/iv_home_alarm"
            app:layout_constraintTop_toTopOf="@+id/iv_home_logo" />

        <!-- 알림 아이콘 -->
        <ImageView
            android:id="@+id/iv_home_alarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="25dp"
            android:src="@drawable/ic_home_alarm"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_home_search" />

        <!-- 타이틀 텍스트 -->
        <TextView
            android:id="@+id/tv_home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘도 챌린지를 해볼까요?"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:fontFamily="@font/noto_sans_kr_bold"
            android:includeFontPadding="false"
            app:layout_constraintTop_toBottomOf="@id/iv_home_logo"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="26dp"
            android:layout_marginStart="16dp"/>

        <!-- 서브 텍스트 -->
        <TextView
            android:id="@+id/tv_home_sub_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="안녕하세요, 김흐르 님! 챌린지에 참가해보세요."
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            app:layout_constraintTop_toBottomOf="@id/tv_home_title"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="5dp"
            android:layout_marginStart="16dp"/>

        <!-- 챌린지 참가 프레임 레이아웃 -->
        <FrameLayout
            android:id="@+id/layout_home_challenge_participate"
            android:layout_width="250dp"
            android:layout_height="250dp"
            app:layout_constraintTop_toBottomOf="@id/tv_home_sub_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp">

            <!-- 그라데이션 배경 -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/bg_home_gradation" />

            <!-- 중앙의 남색배경 -->
            <ImageView
                android:layout_width="230dp"
                android:layout_height="230dp"
                android:layout_gravity="center"
                android:src="@drawable/bg_circle_navy" />

            <!-- 캐릭터 이미지 -->
            <ImageView
                android:id="@+id/iv_home_character"
                android:layout_width="230dp"
                android:layout_height="230dp"
                android:src="@drawable/img_home_character"
                android:layout_gravity="center"/>

            <!-- 이미지의 테두리 -->
            <ImageView
                android:id="@+id/iv_home_ring"
                android:layout_width="230dp"
                android:layout_height="230dp"
                android:layout_gravity="center"
                android:src="@drawable/img_home_ring"/>

            <!-- 버튼 FrameLayout -->
            <FrameLayout
                android:id="@+id/layout_home_challenge_button"
                android:layout_width="120dp"
                android:layout_height="35dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="160dp">

                <!-- 버튼 배경 이미지 -->
                <ImageView
                    android:id="@+id/iv_home_challenge_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bg_circle_orange"/>

                <!-- 버튼 위의 텍스트 -->
                <TextView
                    android:id="@+id/tv_home_challenge_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="챌린지 참가하기"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:fontFamily="@font/noto_sans_kr_medium"
                    android:includeFontPadding="false"
                    android:gravity="center"
                    android:layout_gravity="center"/>
            </FrameLayout>

        </FrameLayout>

        <!-- 챌린지 보러가기 텍스트 -->
        <TextView
            android:id="@+id/tv_home_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="챌린지 보러가기"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:includeFontPadding="false"
            app:layout_constraintTop_toBottomOf="@id/iv_home_background"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="48dp"
            android:layout_marginStart="16dp"/>

        <!-- 가로 스크롤 가능한 RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_home_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginStart="16dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/tv_home_category"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:orientation="horizontal"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
