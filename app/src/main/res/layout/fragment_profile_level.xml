<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ProfileLevelFragment"
    android:background="@color/main_active">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".ProfileLevelFragment"
        android:background="@color/main_active">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ll_level_logo_x"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="53dp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_app_logo_color"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="2dp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="4dp"/>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/btn_x"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="7dp"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="10dp"
                android:layout_gravity="end"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/ll_level_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@+id/ll_level_logo_x"
            android:layout_marginTop="30dp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="다음 레벨까지"
                android:fontFamily="@font/font_style"
                android:textFontWeight="700"
                android:includeFontPadding="false"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:layout_marginTop="-3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="다음 레벨까지 남은 여정을 알려드려요!"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="1dp"/>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/fl_level_map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_level_title"
            android:layout_marginTop="7dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:src="@drawable/bg_level_map"
                app:layout_constraintTop_toBottomOf="@+id/ll_level_title"
                android:layout_marginTop="7dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:src="@drawable/bg_level_map_road"
                app:layout_constraintTop_toBottomOf="@+id/ll_level_title"
                android:layout_marginTop="7dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </FrameLayout>
        
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="240dp"
            app:layout_constraintTop_toBottomOf="@+id/fl_level_map"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@color/white">

            <LinearLayout
                android:id="@+id/ll_level_point"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="23dp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내 포인트"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="400"
                    android:includeFontPadding="false"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="2dp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tv_level_mypoint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="149P"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="700"
                    android:includeFontPadding="false"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_level_achieve_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_radius_30_grey_50"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@+id/ll_level_point"
                android:layout_marginTop="13dp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="16dp">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_level_default"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginStart="6dp"
                    android:padding="3.75dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="포인트 150P 달성 : Gold 획득!"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="500"
                    android:includeFontPadding="false"
                    android:textSize="13sp"
                    android:textColor="@color/grey_500"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="11dp"
                    android:layout_marginStart="7dp"/>



            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
