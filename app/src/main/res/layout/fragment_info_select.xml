<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    tools:context=".InfoSelectFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 성별 텍스트 -->
        <TextView
            android:id="@+id/tv_gender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="성별"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="16dp" />

        <!-- 성별 버튼들 -->
        <RadioGroup
            android:id="@+id/radio_group_gender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_gender"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            android:weightSum="3">

            <RadioButton
                android:id="@+id/radio_male"
                android:layout_width="0dp"
                android:layout_height="33dp"
                android:layout_weight="1"
                android:text="남자"
                android:background="@drawable/btn_onboarding"
                android:textColor="@drawable/btn_onboarding_text"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"
                android:layout_marginEnd="10dp"
                android:button="@null"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/radio_female"
                android:layout_width="0dp"
                android:layout_height="33dp"
                android:layout_weight="1"
                android:text="여자"
                android:background="@drawable/btn_onboarding"
                android:textColor="@drawable/btn_onboarding_text"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"
                android:layout_marginEnd="10dp"
                android:button="@null"
                android:gravity="center" />
        </RadioGroup>

        <!-- 연령대 텍스트 -->
        <TextView
            android:id="@+id/tv_age_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="연령대"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/radio_group_gender"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="30dp"
            android:layout_marginStart="16dp" />

        <!-- 연령대 버튼들 -->
        <RadioGroup
            android:id="@+id/radio_group_age"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_age_group"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <RadioButton
                    android:id="@+id/btn_age_10s"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="10대"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="10dp"
                    android:button="@null"
                    android:gravity="center" />

                <RadioButton
                    android:id="@+id/btn_age_20s"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="20대"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="10dp"
                    android:button="@null"
                    android:gravity="center" />

                <RadioButton
                    android:id="@+id/btn_age_30s"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="30대"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:button="@null"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/btn_age_40s"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="40대"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="10dp"
                    android:button="@null"
                    android:gravity="center" />

                <RadioButton
                    android:id="@+id/btn_age_50s"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="50대 이상"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="10dp"
                    android:button="@null"
                    android:gravity="center" />
            </LinearLayout>
        </RadioGroup>

        <!-- 직업 텍스트 -->
        <TextView
            android:id="@+id/tv_info_select_job"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="직업"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/radio_group_age"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="30dp"
            android:layout_marginStart="16dp" />

        <!-- 직업 버튼들 -->
        <RadioGroup
            android:id="@+id/radio_group_job"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_info_select_job"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <RadioButton
                    android:id="@+id/btn_job_student"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="중/고등학생"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="10dp"
                    android:button="@null"
                    android:gravity="center" />

                <RadioButton
                    android:id="@+id/btn_job_university"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="대학생"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="10dp"
                    android:button="@null"
                    android:gravity="center" />

                <RadioButton
                    android:id="@+id/btn_job_seeker"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="취준생"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:button="@null"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/btn_job_office"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="직장인"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="10dp"
                    android:button="@null"
                    android:gravity="center" />

                <RadioButton
                    android:id="@+id/btn_job_housewife"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="주부"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="10dp"
                    android:button="@null"
                    android:gravity="center" />

                <RadioButton
                    android:id="@+id/btn_job_etc"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_weight="1"
                    android:text="기타"
                    android:background="@drawable/btn_onboarding"
                    android:textColor="@drawable/btn_onboarding_text"
                    android:fontFamily="@font/noto_sans_kr_regular"
                    android:includeFontPadding="false"
                    android:button="@null"
                    android:gravity="center" />
            </LinearLayout>
        </RadioGroup>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
