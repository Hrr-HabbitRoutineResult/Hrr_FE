<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 회색 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_line" />

    <!-- 버튼 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <!-- 좋아요 버튼 -->
        <ImageButton
            android:id="@+id/btn_challenge_like"
            android:layout_width="68dp"
            android:layout_height="45dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_button_like"
            android:src="@drawable/btn_challenge_like" />

        <!-- 참가하기 버튼 -->
        <Button
            android:id="@+id/btn_challenge_join"
            android:layout_width="250dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="참가하기"
            android:textSize="16sp"
            android:fontFamily="@font/font_style"
            android:textFontWeight="600"
            android:textColor="@color/white"
            android:includeFontPadding="false"
            android:background="@drawable/btn_navy"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"/>

    </LinearLayout>

</LinearLayout>