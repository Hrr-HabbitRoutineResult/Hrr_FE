<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <TextView
        android:id="@+id/tv_message_other_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/noto_sans_kr_regular"
        android:text="2025년 2월 2일"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:includeFontPadding="false"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 프로필 이미지 -->
    <ImageView
        android:id="@+id/iv_message_profile"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_message_profile_default"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_message_other_date" />

    <!-- 보낸 사람 이름 -->
    <TextView
        android:id="@+id/tv_message_other_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:fontFamily="@font/noto_sans_kr_medium"
        android:includeFontPadding="false"
        android:text="챌린저명"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        app:layout_constraintStart_toEndOf="@id/iv_message_profile"
        app:layout_constraintTop_toBottomOf="@+id/tv_message_other_date" />

    <FrameLayout
        android:id="@+id/layout_message_other_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_message_other"
        android:layout_marginTop="5dp"
        android:padding="10dp"
        android:layout_marginStart="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_message_other_name">

        <!-- 메시지 내용 -->
        <TextView
            android:id="@+id/tv_message_other_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lorem ipsum dolor sit amet consectetur. Venenatis tempus feugiat id sapien in."
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:maxWidth="220dp" />
    </FrameLayout>

    <!-- 메시지 시간 -->
    <TextView
        android:id="@+id/tv_message_other_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:text="오후 2:40"
        android:textColor="@color/text_tertiary"
        android:textSize="12sp"
        android:fontFamily="@font/noto_sans_kr_regular"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toBottomOf="@id/layout_message_other_container"
        app:layout_constraintStart_toEndOf="@id/layout_message_other_container" />

</androidx.constraintlayout.widget.ConstraintLayout>
