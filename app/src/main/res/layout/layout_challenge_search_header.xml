<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="42.5dp"
        android:layout_marginBottom="10dp">

        <!-- 뒤로가기 버튼 -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="center"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"><!-- 타이틀 -->
            <EditText
                android:id="@+id/et_search_challenge"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/bg_searchbox"
                android:hint="검색어를 입력하세요"
                android:textColorHint="@color/text_tertiary"
                android:textSize="13sp"
                android:paddingStart="44dp"
                android:layout_marginEnd="10dp"
                android:textCursorDrawable="@drawable/cursor_custom"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_erase_search"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 돋보기 아이콘 -->
            <ImageView
                android:id="@+id/iv_search"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp" />

            <!-- x 아이콘 -->
            <ImageView
                android:id="@+id/iv_erase_search"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/btn_erase_search"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" /></FrameLayout>
    </LinearLayout>

    <!-- 회색 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/grey_50" />

</LinearLayout>