<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:orientation="vertical"
        android:background="@drawable/bg_top_radius10"
        android:paddingBottom="21dp"
        android:clipToOutline="true">

    <FrameLayout
            android:id="@+id/fl_withdrawal_top"
            android:layout_width="match_parent"
            android:layout_height="95dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
                android:id="@+id/ll_withdrawal_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="35dp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="10dp">

            <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/btn_arrow_left"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="16dp"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="회원 탈퇴"
                    android:textSize="20sp"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="600"
                    android:includeFontPadding="false"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="20dp"/>

        </LinearLayout>

    </FrameLayout>

    <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical">

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="회원 탈퇴 하시겠어요?"
                android:textSize="15sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textColor="@color/text_primary"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="회원 탈퇴 시 챌린지 현황을 비롯한 모든 정보와 계정이 삭제되며
\n한번 삭제된 계정은 되돌릴 수 없습니다."
                android:textSize="12sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textColor="@color/text_tertiary"
                android:layout_marginTop="20dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="회원 탈퇴 후 재가입은 1개월이 지나야 가능합니다.
\n그래도 탈퇴를 진행하시겠어요?"
                android:textSize="12sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textColor="@color/text_tertiary"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="62dp"/>

    </LinearLayout>

    <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"
            android:layout_marginTop="92dp"/>

    <LinearLayout
            android:id="@+id/ll_withdrawal_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="61dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_no_withdrawal"
                android:layout_width="160dp"
                android:layout_height="45dp"
                android:layout_marginEnd="8dp"
                android:text="돌아가기"
                android:textSize="16sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="600"
                android:textColor="@color/white"
                android:includeFontPadding="false"
                android:background="@drawable/btn_navy"
                android:stateListAnimator="@null" />

        <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_withdrawal"
                android:layout_width="160dp"
                android:layout_height="45dp"
                android:text="탈퇴하기"
                android:textSize="16sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="600"
                android:textColor="@color/text_tertiary"
                android:includeFontPadding="false"
                android:background="@drawable/bg_button_like"
                android:stateListAnimator="@null" />

    </LinearLayout>


</LinearLayout>