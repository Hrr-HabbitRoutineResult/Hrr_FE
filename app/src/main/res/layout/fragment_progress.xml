<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".challenge.ui.record.ProgressFragment">

    <!-- 상단 헤더 영역 -->
    <include
        android:id="@+id/layout_record_header"
        layout="@layout/layout_record_header" />

    <!-- 탭 레이아웃 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tl_progress"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginBottom="9dp"
        app:layout_constraintTop_toBottomOf="@id/layout_record_header"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabRippleColor="@null"
        app:tabSelectedTextColor="@color/text_primary"
        app:tabTextColor="@color/text_tertiary"
        app:tabBackground="@android:color/transparent"
        app:tabIndicator="@drawable/tab_indicator_profile"
        app:tabIndicatorColor="@android:color/transparent"
        android:background="@android:color/transparent"
        app:tabPaddingTop="7dp"
        app:tabTextAppearance="@style/TabTextAppearance">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="마이" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="챌린저"/>

    </com.google.android.material.tabs.TabLayout>

    <!-- 뷰페이저 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_progress"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="9dp"
        app:layout_constraintTop_toBottomOf="@id/tl_progress"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>