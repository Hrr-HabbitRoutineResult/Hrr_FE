<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginStart="12.5dp"
    android:layout_marginEnd="12.5dp"
    android:layout_marginTop="25dp">

    <!-- 뱃지 아이콘 -->
    <ImageView
        android:id="@+id/iv_edit_badge_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/img_badge_challenge_01"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!--  체크 아이콘  -->
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_badge_selected"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone"/>

    <!-- 뱃지명 -->
    <TextView
        android:id="@+id/tv_edit_badge_name"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:text="뱃지명"
        android:maxLines="1"
        android:gravity="center"
        android:fontFamily="@font/font_style"
        android:textFontWeight="400"
        android:includeFontPadding="false"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toBottomOf="@+id/iv_edit_badge_icon"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>