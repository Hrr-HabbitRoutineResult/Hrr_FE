<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ns_profile"
    tools:context=".ProfileFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    android:descendantFocusability="blocksDescendants">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Profile Frame -->
        <FrameLayout
            android:id="@+id/fl_topBanner_profile"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@color/main_active"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_profile_logo"
            android:layout_width="25dp"
            android:layout_height="29dp"
            android:layout_marginStart="22dp"
            android:layout_marginTop="37dp"
            android:src="@drawable/ic_logo"
            app:layout_constraintStart_toStartOf="@+id/fl_topBanner_profile"
            app:layout_constraintTop_toTopOf="@+id/fl_topBanner_profile" />

        <ImageView
            android:id="@+id/iv_profile_menu"
            android:layout_width="26dp"
            android:layout_height="32dp"
            android:layout_marginTop="38dp"
            android:layout_marginEnd="20dp"
            android:src="@drawable/btn_profile_menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.mikhaellopez.circularprogressbar.CircularProgressBar
            android:id="@+id/cpb_profile_levelGauge"
            android:layout_width="124dp"
            android:layout_height="124dp"
            android:layout_marginTop="88dp"
            app:cpb_background_progressbar_color="@color/white"
            app:cpb_background_progressbar_width="22dp"
            app:cpb_progressbar_color="@color/sub_01"
            app:cpb_progressbar_width="22dp"
            app:cpb_start_angle="-90"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/fl_topBanner_profile" />

        <ImageView
            android:id="@+id/iv_profile_userBgImage"
            android:layout_width="102dp"
            android:layout_height="102dp"
            android:layout_marginTop="99dp"
            android:src="@drawable/ic_profile_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/fl_topBanner_profile" />

        <ImageView
            android:id="@+id/iv_profile_userImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="110dp"
            android:src="@drawable/ic_profile_default"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/fl_topBanner_profile" />

        <TextView
            android:id="@+id/tv_profile_edit"
            android:layout_width="92dp"
            android:layout_height="28dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/round_border"
            android:text="프로필 수정"
            android:fontFamily="@font/font_style"
            android:textFontWeight="500"
            android:includeFontPadding="false"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fl_topBanner_profile" />

        <TextView
            android:id="@+id/tv_profile_username"
            android:layout_width="wrap_content"
            android:layout_height="29dp"
            android:layout_marginTop="5dp"
            android:text="열 자가 최대라길래"
            android:textAlignment="center"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_profile_userImage"
            android:fontFamily="@font/font_style"
            android:textFontWeight="600"
            android:includeFontPadding="false"/>

        <LinearLayout
            android:id="@+id/ll_profile_rank"
            android:layout_width="wrap_content"
            android:layout_height="17dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_profile_username">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="17dp"
                android:text="등급"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"/>

            <ImageView
                android:layout_width="3dp"
                android:layout_height="7dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="3dp"
                android:src="@drawable/btn_rank_more" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_profile_follow"
            android:layout_width="wrap_content"
            android:layout_height="17dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_profile_rank"
            android:layout_marginTop="5dp"
            android:fontFamily="@font/font_style"
            android:textFontWeight="400"
            android:includeFontPadding="false">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="17dp"
                android:text="00"
                android:textSize="12sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="17dp"
                android:text="팔로워"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:layout_marginStart="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="17dp"
                android:text="00"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:layout_marginStart="13dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="17dp"
                android:text="팔로잉"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:layout_marginStart="5dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_profile_badge"
            android:layout_width="wrap_content"
            android:layout_height="61dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_profile_follow"
            android:layout_marginTop="20dp"
            android:gravity="center_horizontal"
            android:fontFamily="@font/font_style"
            android:textFontWeight="400"
            android:includeFontPadding="false">

            <LinearLayout
                android:id="@+id/ll_profile_badge_01"
                android:layout_width="62dp"
                android:layout_height="61dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iv_profile_badge_01"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/btn_badge_default"/>

                <TextView
                    android:id="@+id/tv_profile_badge_01"
                    android:layout_width="match_parent"
                    android:layout_height="17dp"
                    android:text="추가"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="400"
                    android:includeFontPadding="false"
                    android:gravity="center"
                    android:ellipsize="end"
                    android:maxLines="1"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_profile_badge_02"
                android:layout_width="62dp"
                android:layout_height="61dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone"
                android:layout_marginStart="10dp">

                <ImageView
                    android:id="@+id/iv_profile_badge_02"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/btn_badge_default"/>

                <TextView
                    android:id="@+id/tv_profile_badge_02"
                    android:layout_width="match_parent"
                    android:layout_height="17dp"
                    android:text="추가"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="400"
                    android:includeFontPadding="false"
                    android:gravity="center"
                    android:ellipsize="end"
                    android:maxLines="1"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_profile_badge_03"
                android:layout_width="62dp"
                android:layout_height="61dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone"
                android:layout_marginStart="10dp">

                <ImageView
                    android:id="@+id/iv_profile_badge_03"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/btn_badge_default"/>

                <TextView
                    android:id="@+id/tv_profile_badge_03"
                    android:layout_width="match_parent"
                    android:layout_height="17dp"
                    android:text="추가"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="400"
                    android:includeFontPadding="false"
                    android:gravity="center"
                    android:ellipsize="end"
                    android:maxLines="1"/>
            </LinearLayout>

        </LinearLayout>

        <!--Content Frame-->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tl_profile"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            app:layout_constraintTop_toBottomOf="@+id/ll_profile_badge"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="23dp"
            app:tabTextColor="@color/text_tertiary"
            app:tabSelectedTextColor="@color/text_primary"
            app:tabIndicator="@drawable/tab_indicator_profile"
            app:tabIndicatorColor="@android:color/transparent"
            android:fontFamily="@font/font_style"
            android:textFontWeight="400"
            android:includeFontPadding="false"/>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vp_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/tl_profile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
