<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ProfileFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/topBanner_profile"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@color/main_active"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_profile_logo"
            android:layout_width="25dp"
            android:layout_height="29dp"
            android:layout_marginStart="22dp"
            android:layout_marginTop="37dp"
            android:src="@drawable/ic_logo"
            app:layout_constraintStart_toStartOf="@+id/topBanner_profile"
            app:layout_constraintTop_toTopOf="@+id/topBanner_profile" />

        <ImageView
            android:id="@+id/iv_profile_menu"
            android:layout_width="26dp"
            android:layout_height="32dp"
            android:layout_marginTop="38dp"
            android:layout_marginEnd="20dp"
            android:src="@drawable/ic_menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
