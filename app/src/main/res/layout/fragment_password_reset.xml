<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="55dp">

    <TextView
        android:id="@+id/tv_reset_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/noto_sans_kr_bold"
        android:includeFontPadding="false"
        android:text="새로운 비밀번호를\n입력해주세요"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="35dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_reset_title">

        <!-- 이메일 표시 -->
        <TextView
            android:id="@+id/tv_reset_email"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:gravity="center"
            android:text="1234****@naver.com"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:background="@drawable/bg_square_grey_10"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 안내 문구 -->
        <TextView
            android:id="@+id/tv_reset_password_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:gravity="center"
            android:text="해당 계정의 새로운 비밀번호를 설정해주세요."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:includeFontPadding="false"
            android:layout_marginTop="15dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_reset_email" />

        <!-- 선 (구분선) -->
        <View
            android:id="@+id/line_reset_first"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="25dp"
            android:background="@color/text_line"
            app:layout_constraintTop_toBottomOf="@id/tv_reset_password_description"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 비밀번호 레이블 -->
        <LinearLayout
            android:id="@+id/tv_reset_password_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="45dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/line_reset_first">

            <TextView
                android:id="@+id/tv_reset_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans_kr_medium"
                android:includeFontPadding="false"
                android:text="새 비밀번호"
                android:textColor="@android:color/black"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_reset_password_required"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans_kr_medium"
                android:includeFontPadding="false"
                android:text=" *"
                android:textColor="@color/sub_01"
                android:textSize="13sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/layout_reset_password"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_reset_password_label">

            <!-- 비밀번호 입력 필드 -->
            <EditText
                android:id="@+id/et_reset_password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_field"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:hint="비밀번호를 입력해주세요"
                android:includeFontPadding="false"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="40dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textCursorDrawable="@drawable/cursor_custom"
                android:textSize="14sp" />

            <!-- 비밀번호 유효성 검사 결과 에러 아이콘 -->
            <ImageView
                android:id="@+id/iv_reset_password_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_signup_error"
                android:visibility="gone" />
        </FrameLayout>


        <!-- 비밀번호 안내 문구 -->
        <TextView
            android:id="@+id/tv_reset_password_helper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:paddingHorizontal="5dp"
            android:text="8자~20자 이하, 영대소문자, 숫자, 특수기호 2가지 이상 조합"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_reset_password" />

        <!-- 비밀번호 확인 레이블 -->
        <LinearLayout
            android:id="@+id/tv_reset_password_confirm_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_reset_password_helper">

            <TextView
                android:id="@+id/tv_signup_confirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans_kr_medium"
                android:includeFontPadding="false"
                android:text="비밀번호 확인"
                android:textColor="@android:color/black"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_signup_confirm_required"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans_kr_medium"
                android:includeFontPadding="false"
                android:text=" *"
                android:textColor="@color/sub_01"
                android:textSize="13sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/layout_reset_password_confirm"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv_reset_password_confirm_label">

            <!-- 비밀번호 확인 입력 필드 -->
            <EditText
                android:id="@+id/et_reset_password_confirm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_field"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:hint="비밀번호를 다시 입력해주세요"
                android:includeFontPadding="false"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="40dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textCursorDrawable="@drawable/cursor_custom"
                android:textSize="14sp" />

            <!-- 비밀번호 확인 유효성 검사 아이콘 -->
            <ImageView
                android:id="@+id/iv_reset_password_confirm_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_signup_error"
                android:visibility="gone" />
        </FrameLayout>


        <!-- 비밀번호 확인 에러 문구 -->
        <TextView
            android:id="@+id/tv_reset_password_confirm_helper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="5dp"
            android:text="비밀번호가 일치하지 않습니다."
            android:textSize="12sp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:textColor="@color/sub_01"
            android:visibility="gone"
            android:layout_marginTop="7dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_reset_password_confirm"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 선 (구분선) -->
    <View
        android:id="@+id/line_reset_second"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="14dp"
        android:background="@color/text_line"
        app:layout_constraintBottom_toTopOf="@id/btn_reset_password_next"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 다음 버튼 -->
    <FrameLayout
        android:id="@+id/btn_reset_password_next"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 배경 이미지 -->
        <ImageView
            android:id="@+id/iv_reset_password_next"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/btn_access_color" />

        <!-- 버튼 텍스트 -->
        <TextView
            android:id="@+id/tv_reset_password_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="확인"
            android:textColor="@drawable/btn_access_text_color"
            android:textSize="16sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:layout_gravity="center"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
