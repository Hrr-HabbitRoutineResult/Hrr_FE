<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/ns_challenge_list"
    tools:context=".ChallengeListFragment">

    <LinearLayout
        android:id="@+id/ll_challenge_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 상단 헤더 영역 -->
        <include layout="@layout/layout_challenge_list_header" />

        <!-- 필터1 영역 -->
        <include layout="@layout/layout_challenge_list_filter1" />

        <!-- 필터2 영역 -->
        <include layout="@layout/layout_challenge_list_filter2" />

    </LinearLayout>

    <!--챌린지 목록 영역-->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_challenge_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@+id/ll_challenge_list"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="vertical"/>

    <!-- 챌린지 개설 버튼 영역 -->
    <ImageView
        android:id="@+id/iv_create_challenge"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="65dp"
        android:src="@drawable/btn_create_challenge"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>