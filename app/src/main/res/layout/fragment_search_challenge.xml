<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/layout_challenge_search_header"
        android:id="@+id/layout_challenge_search_header"/>

    <!-- 챌린지 검색할 때 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_search_challenge"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="visible">

        <ImageView
            android:id="@+id/iv_search_challenge"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/ic_challenge_search_info"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="101dp"/>

        <TextView
            android:id="@+id/tv_challenge_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="원하는 챌린지가 없으신가요?"
            android:textSize="18sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:textColor="@color/grey_500"
            app:layout_constraintTop_toBottomOf="@id/iv_search_challenge"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 버튼-->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_challenge_search"
            android:layout_marginTop="20dp"
            >

            <ImageView
                android:id="@+id/btn_create_challenge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_circle_orange" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="챌린지 개설하기"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:fontFamily="@font/noto_sans_kr_semi_bold"
                android:layout_gravity="center"
                android:layout_marginBottom="5.5dp"/>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 검색한 챌린지 목록 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_search_challenge_o"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="110dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <include layout="@layout/layout_challenge_list_filter2"
            android:id="@+id/layout_challenge_list_filter2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_challenge_list_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="47dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 검색한 챌린지 없을 때 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_search_challenge_x"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="234dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_search_challenge_x"
            android:layout_width="103dp"
            android:layout_height="130dp"
            android:src="@drawable/ic_challenge_search_info_x"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_challenge_search_x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="검색 결과가 없어요"
            android:textSize="18sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:textColor="@color/text_tertiary"
            app:layout_constraintTop_toBottomOf="@id/iv_search_challenge_x"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>