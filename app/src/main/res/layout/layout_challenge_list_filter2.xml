<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- 체크박스 -->
    <android.widget.CheckBox
        android:id="@+id/cb_available_challenge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:button="@drawable/cb_custom"
        android:fontFamily="@font/noto_sans_kr_medium"
        android:includeFontPadding="false"
        android:text="참여 가능 챌린지만"
        android:textColor="@color/text_tertiary"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

        <!-- 이미지 아이콘 -->
    <ImageView
        android:id="@+id/iv_challenge_spinner"
        android:layout_width="11dp"
        android:layout_height="12dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="9dp"
        android:src="@drawable/ic_challenge_spinner"
        app:layout_constraintEnd_toStartOf="@id/spinner_filter"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Spinner -->
    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/spinner_filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:spinnerMode="dropdown"
        android:background="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

