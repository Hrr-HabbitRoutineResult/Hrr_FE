<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ProfileMoreActivity">

    <FrameLayout
        android:id="@+id/fl_challenge_more_top"
        android:layout_width="match_parent"
        android:layout_height="95dp"
        android:background="@drawable/bg_border1_grey50"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/ll_challenge_more_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="45dp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/iv_profile_more_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/btn_arrow_left"
                android:layout_marginTop="10dp"
                android:layout_marginStart="16dp"/>

            <TextView
                android:id="@+id/tv_profile_more_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="완주 챌린지"
                android:textSize="20sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="600"
                android:includeFontPadding="false"
                android:layout_marginTop="4dp"
                android:layout_marginStart="20dp"/>

        </LinearLayout>

    </FrameLayout>

    <FrameLayout
        android:id="@+id/fl_profile_more_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/fl_challenge_more_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>