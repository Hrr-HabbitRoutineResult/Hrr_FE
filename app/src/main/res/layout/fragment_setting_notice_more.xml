<?xml version="1.0" encoding="utf-8"?>
<ScrollView
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="match_parent"
tools:context=".SettingNoticeMoreFragment">

<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="35dp"
        android:paddingStart="24dp"
        android:paddingEnd="25dp"
        android:paddingBottom="96dp">

    <!--   챌린지 알림 헤더     -->
    <LinearLayout
            android:id="@+id/ll_notice_challenge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="6dp">

        <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="챌린지 알림"
                android:fontFamily="@font/font_style"
                android:textFontWeight="600"
                android:includeFontPadding="false"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:layout_weight="1"/>

    </LinearLayout>

    <!--   챌린지 퇴출     -->
    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingVertical="20dp">

        <TextView
                android:id="@+id/tv_notice_challenge_out"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="챌린지 퇴출"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="챌린지에서 퇴출되었을 때 알려드립니다"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@+id/tv_notice_challenge_out"
                android:layout_marginTop="6dp"
                app:layout_constraintStart_toStartOf="parent"/>

        <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_notice_challenge_out"
                android:layout_width="50dp"
                android:layout_height="25dp"
                android:layout_gravity="center_vertical"
                style="@style/custom_toggle"
                android:padding="3dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"/>


    <!--   부실 인증 경고 알림     -->
    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingVertical="20dp">

        <TextView
                android:id="@+id/tv_weak_certify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="부실 인증 경고"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="챌린지에서 부실 인증으로 경고를 받았을 때
\n알려드립니다"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@+id/tv_weak_certify"
                android:layout_marginTop="6dp"
                app:layout_constraintStart_toStartOf="parent"/>

        <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_weak_certify"
                android:layout_width="50dp"
                android:layout_height="25dp"
                android:layout_gravity="center_vertical"
                style="@style/custom_toggle"
                android:padding="3dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"/>

    <!--   나 또는 업로드된 인증글 관련 알림 헤더     -->
    <LinearLayout
            android:id="@+id/ll_notice_certify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="6dp"
            android:layout_marginTop="55dp">

        <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="나 또는 업로드된 인증글 관련"
                android:fontFamily="@font/font_style"
                android:textFontWeight="600"
                android:includeFontPadding="false"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:layout_weight="1"/>

    </LinearLayout>

    <!--   내 인증 댓글 알림     -->
    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingVertical="20dp">

        <TextView
                android:id="@+id/tv_notice_my_certify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내 인증 댓글"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내가 업로드한 질문 인증 혹은 일반 인증글에
\n새로운 댓글이 달렸을 때 알려드립니다"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@+id/tv_notice_my_certify"
                android:layout_marginTop="6dp"
                app:layout_constraintStart_toStartOf="parent"/>

        <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_notice_my_certify"
                android:layout_width="50dp"
                android:layout_height="25dp"
                android:layout_gravity="center_vertical"
                style="@style/custom_toggle"
                android:padding="3dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"/>

    <!--   챌린지 질문 등록 알림     -->
    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingVertical="20dp">

        <TextView
                android:id="@+id/tv_new_challenge_ask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="챌린지 질문 등록"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="챌린지에 새로운 질문 인증글이 업로드됐을 때
\n알려드립니다"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@+id/tv_new_challenge_ask"
                android:layout_marginTop="6dp"
                app:layout_constraintStart_toStartOf="parent"/>

        <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_new_challenge_ask"
                android:layout_width="50dp"
                android:layout_height="25dp"
                android:layout_gravity="center_vertical"
                style="@style/custom_toggle"
                android:padding="3dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_line"/>

</LinearLayout>

</ScrollView>
