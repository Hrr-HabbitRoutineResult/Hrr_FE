<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="15dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- 챌린지 대표 이미지 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="197dp"
        app:cardCornerRadius="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/iv_profile_completedChallenge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/img_cook"
                android:scaleType="fitCenter" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_completed_challenge"/>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- 완료 도장 -->
    <ImageView
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:src="@drawable/img_complete"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="27dp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="80dp"
        android:elevation="2dp"/>

    <!-- 챌린지명 -->
    <TextView
        android:id="@+id/tv_profile_completedChallenge_detail_title"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:text="흑백요리가 나가실 분"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:fontFamily="@font/font_style"
        android:textFontWeight="500"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/tv_profile_completedChallenge_detail_subtitle"
        android:layout_marginBottom="3dp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="15dp"
        android:elevation="2dp"/>

    <!-- 챌린지 한 줄 소개 -->
    <TextView
        android:id="@+id/tv_profile_completedChallenge_detail_subtitle"
        android:layout_width="match_parent"
        android:layout_height="17dp"
        android:text="흑백요리사 시즌 4쯤에 나가는 걸 목표로"
        android:textSize="12sp"
        android:textColor="@color/grey_400"
        android:fontFamily="@font/font_style"
        android:textFontWeight="400"
        android:includeFontPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="19dp"
        android:elevation="2dp"
        android:ellipsize="end"
        android:maxLines="1"/>

</androidx.constraintlayout.widget.ConstraintLayout>