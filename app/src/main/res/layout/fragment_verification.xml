<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="55dp">

    <TextView
        android:id="@+id/tv_verification_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/noto_sans_kr_bold"
        android:includeFontPadding="false"
        android:text="비밀번호를 잊으셨나요?"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_verification_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/noto_sans_kr_regular"
        android:includeFontPadding="false"
        android:text="가입할 때 등록한 이메일 정보로\n임시 비밀번호를 발급 받을 수 있어요."
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_verification_title" />

    <!-- 이메일 입력 레이블 -->
    <LinearLayout
        android:id="@+id/layout_verification_email_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="70dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_verification_description">

        <TextView
            android:id="@+id/tv_verification_email_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이메일"
            android:textSize="13sp"
            android:fontFamily="@font/noto_sans_kr_medium"
            android:includeFontPadding="false"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tv_verification_email_required"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" *"
            android:textSize="13sp"
            android:fontFamily="@font/noto_sans_kr_medium"
            android:includeFontPadding="false"
            android:textColor="@color/sub_01"/>
    </LinearLayout>

    <!-- 이메일 입력 필드 -->
    <FrameLayout
        android:id="@+id/layout_verification_email"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="9dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_verification_email_label">

        <EditText
            android:id="@+id/et_verification_email"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="이메일을 입력해주세요"
            android:background="@drawable/bg_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="40dp"
            android:inputType="textEmailAddress"
            android:textSize="14sp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:textColorHint="@color/text_tertiary"
            android:textColor="@color/text_primary"
            android:textCursorDrawable="@drawable/cursor_custom" />

        <!-- 전송 버튼 -->
        <FrameLayout
            android:id="@+id/btn_verification_send"
            android:layout_width="50dp"
            android:layout_height="28dp"
            android:layout_marginEnd="14dp"
            android:layout_gravity="end|center_vertical"
            android:background="@drawable/btn_grey_30">

            <TextView
                android:id="@+id/tv_verification_send"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="전송"
                android:textColor="#AEB2B8"
                android:textSize="12sp"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"
                android:gravity="center"/>
        </FrameLayout>
    </FrameLayout>

    <!-- 인증번호 입력 필드 -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_verification_email">

        <EditText
            android:id="@+id/et_verification"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="인증코드를 입력해주세요"
            android:background="@drawable/bg_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="40dp"
            android:textSize="14sp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"
            android:textColorHint="@color/text_tertiary"
            android:textColor="@color/text_primary"
            android:textCursorDrawable="@drawable/cursor_custom" />

        <!-- 인증 버튼 -->
        <FrameLayout
            android:id="@+id/btn_verification"
            android:layout_width="50dp"
            android:layout_height="28dp"
            android:layout_marginEnd="14dp"
            android:layout_gravity="end|center_vertical"
            android:background="@drawable/btn_grey_30">

            <TextView
                android:id="@+id/tv_verification"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="인증"
                android:textColor="#AEB2B8"
                android:textSize="12sp"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"
                android:gravity="center"/>
        </FrameLayout>
    </FrameLayout>

    <!-- 선 (구분선) -->
    <View
        android:id="@+id/line_verification"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="14dp"
        android:background="@color/text_line"
        app:layout_constraintBottom_toTopOf="@id/btn_verification_next"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 다음 버튼 -->
    <FrameLayout
        android:id="@+id/btn_verification_next"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 배경 이미지 -->
        <ImageView
            android:id="@+id/iv_verification_next"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/btn_access_color" />

        <!-- 버튼 텍스트 -->
        <TextView
            android:id="@+id/tv_verification_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="확인"
            android:textColor="@drawable/btn_access_text_color"
            android:textSize="16sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:layout_gravity="center"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
