<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".challenge.certification.ui.text.TextCertificationFragment">

    <!-- 상단 헤더 영역 -->
    <LinearLayout
        android:id="@+id/ll_certification_header"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="45dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 뒤로가기 버튼 -->
        <ImageButton
            android:id="@+id/btn_certification_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="center"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- 타이틀 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="글쓰기"
            android:textSize="20sp"
            android:fontFamily="@font/font_style"
            android:textFontWeight="600"
            android:textColor="@color/text_primary"
            android:includeFontPadding="false" />

        <!-- 완료 버튼 -->
        <TextView
            android:id="@+id/tv_certification_complete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="완료"
            android:textSize="16sp"
            android:fontFamily="@font/font_style"
            android:textFontWeight="600"
            android:textColor="@color/grey_500"
            android:includeFontPadding="false"
            android:layout_marginEnd="16dp"/>

    </LinearLayout>

    <!-- 회색 구분선 -->
    <View
        android:id="@+id/view_certification_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/grey_50"
        app:layout_constraintTop_toBottomOf="@id/ll_certification_header"/>

    <!-- 내용 입력 영역 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingHorizontal="18dp"
        app:layout_constraintTop_toBottomOf="@id/view_certification_divider"
        app:layout_constraintBottom_toTopOf="@id/view_certification_bottom_divider">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 제목 입력 -->
            <EditText
                android:id="@+id/et_certification_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="제목"
                android:textSize="15sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:textColorHint="@color/text_tertiary"
                android:includeFontPadding="false"
                android:layout_marginTop="15dp"
                android:inputType="text"
                android:maxLines="1"
                android:paddingVertical="8dp"/>

            <!-- 제목 입력 구분선 -->
            <View
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:background="@color/text_line"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"/>

            <!-- 첨부한 이미지 영역 -->
            <ImageView
                android:id="@+id/iv_certification_image"
                android:layout_width="326dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:adjustViewBounds="true"
                android:visibility="gone"
                android:background="@drawable/bg_radius15"
                android:clipToOutline="true"
                android:layout_marginBottom="20dp"/>

            <!-- 첨부한 링크 영역 -->
            <LinearLayout
                android:id="@+id/ll_certification_preview"
                android:layout_width="326dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_certification_link"/>

                <TextView
                    android:id="@+id/tv_certification_link"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:ellipsize="end"
                    android:maxLines="1"/>

            </LinearLayout>

            <!-- 내용 입력 -->
            <EditText
                android:id="@+id/et_certification_content"
                android:layout_width="wrap_content"
                android:layout_height="232dp"
                android:background="@null"
                android:gravity="top"
                android:hint="내용을 입력하세요. (200자 이내)"
                android:textSize="12sp"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"
                android:textColorHint="@color/text_tertiary"/>

            <!-- 내용 입력 구분선 -->
            <View
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:background="@color/text_line"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="15dp"/>

            <!-- 질문 체크박스 -->
            <android.widget.CheckBox
                android:id="@+id/cb_certification_question"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:text="질문"
                android:textSize="15sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:textColor="@color/text_tertiary"
                android:includeFontPadding="false"
                android:paddingStart="7dp"
                android:button="@drawable/cb_custom" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 하단 구분선 -->
    <View
        android:id="@+id/view_certification_bottom_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/grey_50"
        app:layout_constraintBottom_toTopOf="@id/ll_certification_buttons"/>

    <!-- 하단 버튼 영역 -->
    <LinearLayout
        android:id="@+id/ll_certification_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:windowSoftInputMode="adjustPan"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btn_certification_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@null"
            android:src="@drawable/ic_certification_gallery"/>

        <ImageButton
            android:id="@+id/btn_certification_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@null"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_certification_link"/>

        <!-- 임시저장 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/tv_certification_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="임시저장"
                android:textSize="15sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:textColor="@color/text_tertiary"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="|"
                android:textSize="14sp"
                android:textColor="@color/text_line"
                android:layout_marginHorizontal="4dp"/>

            <TextView
                android:id="@+id/tv_certification_temp_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="15sp"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:textColor="@color/text_tertiary"
                android:includeFontPadding="false"
                android:layout_marginStart="8dp"/>
            
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>