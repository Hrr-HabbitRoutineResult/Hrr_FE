<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginTop="21dp"
    android:layout_marginBottom="25dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp">

    <TextView
        android:id="@+id/tv_profile_certification_record_content_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="챌린지명"
        android:textSize="15sp"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/font_style"
        android:textFontWeight="500"
        android:includeFontPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tv_profile_certification_record_content_title"
        android:layout_width="62dp"
        android:layout_height="wrap_content"
        android:text="게시글 제목"
        android:textSize="13sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="@font/font_style"
        android:textFontWeight="500"
        android:includeFontPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/tv_profile_certification_record_content_name"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toStartOf="parent"
        android:ellipsize="end"
        android:maxLines="1"/>

    <ImageView
        android:layout_width="13dp"
        android:layout_height="13dp"
        android:src="@drawable/ic_with_link"
        app:layout_constraintTop_toBottomOf="@+id/tv_profile_certification_record_content_name"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toEndOf="@+id/tv_profile_certification_record_content_title"
        android:layout_marginStart="8dp"/>

    <TextView
        android:id="@+id/tv_profile_certification_record_content_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2024.12.31"
        android:textSize="12sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="@font/font_style"
        android:textFontWeight="500"
        android:includeFontPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/tv_profile_certification_record_content_title"
        android:layout_marginTop="11dp"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/iv_profile_certification_record_content_img"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@drawable/img_running"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="2dp"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>