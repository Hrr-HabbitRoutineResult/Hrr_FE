<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".challenge.certification.ui.post.PostFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/sv_post_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/ll_post_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 상단 헤더 영역 -->
            <include
                android:id="@+id/layout_record_header"
                layout="@layout/layout_record_header"/>

            <!-- 게시물 프로필 영역 -->
            <include
                android:id="@+id/layout_post_profile"
                layout="@layout/layout_post_profile"/>

            <!-- 게시물 내용 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/tv_post_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="해피뉴이어~! 올해 마지막 인증합니다."
                    android:textSize="16sp"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="600"
                    android:textColor="@color/text_primary"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tv_post_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="다들 한 해 어떻게 보내셨는지 모르겠지만 아쉬움은 2024년에 남기고 2025년은 더욱 행복하게 보내보아요! 이번 주 스터디 자료는 아래 블로그 링크로 첨부하였습니다.
\n그리고 해결 못한 부분이 있는데 한 번 확인해주실 수 있을까요?"
                    android:textSize="12sp"
                    android:fontFamily="@font/font_style"
                    android:textFontWeight="400"
                    android:textColor="@color/text_primary"
                    android:includeFontPadding="false"
                    android:layout_marginTop="10dp"/>

                <!-- 첨부한 링크 영역 -->
                <LinearLayout
                    android:layout_width="328dp"
                    android:layout_height="30dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="25dp"
                    android:layout_marginBottom="30dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_radius15_grey50">

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_post_link"/>

                    <TextView
                        android:id="@+id/tv_post_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:text="https://lection.blog.naver.com/BlogHome"
                        android:textSize="12sp"
                        android:fontFamily="@font/font_style"
                        android:textFontWeight="400"
                        android:textColor="@color/text_secondary"
                        android:includeFontPadding="false"
                        android:layout_marginStart="6dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- 중간 구분선 -->
            <View
                android:layout_width="348dp"
                android:layout_height="1dp"
                android:layout_gravity="center_horizontal"
                android:background="@color/text_line"/>

            <!-- 게시물 액션 버튼 영역-->
            <include
                layout="@layout/layout_post_buttons" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 댓글 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_comments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/sv_post_content"
        app:layout_constraintBottom_toTopOf="@id/layout_comment_input"/>

    <!-- 하단 댓글 입력 영역 -->
    <include
        android:id="@+id/layout_comment_input"
        layout="@layout/layout_comment_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="40dp"/>

    <!-- 바텀시트 레이아웃 추가 -->
    <include
        android:id="@+id/layout_dialog_bottom_sheet"
        layout="@layout/dialog_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>