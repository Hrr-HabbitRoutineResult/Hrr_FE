<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".access.ui.LoginActivity"
    android:background="@color/white">

    <ImageView
        android:id="@+id/iv_login_bg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_login_gradient" />

    <!-- 둥근 흰색 배경 추가 -->
    <LinearLayout
        android:id="@+id/layout_login_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_login_rounded"
        android:paddingHorizontal="24dp"
        android:paddingTop="110dp"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 이메일 입력 필드 -->
        <EditText
            android:id="@+id/et_login_email"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_field"
            android:hint="이메일"
            android:paddingHorizontal="16dp"
            android:textColorHint="@color/text_tertiary"
            android:textSize="15sp"
            android:textCursorDrawable="@drawable/cursor_custom"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"/>

        <!-- 비밀번호 입력 필드 -->
        <EditText
            android:id="@+id/et_login_password"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:hint="비밀번호"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColorHint="@color/text_tertiary"
            android:textSize="15sp"
            android:textCursorDrawable="@drawable/cursor_custom"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:includeFontPadding="false"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="25dp">

            <ImageView
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/btn_navy"/>

            <TextView
                android:id="@+id/btn_login_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="로그인"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/noto_sans_kr_semi_bold"
                android:layout_gravity="center"/>
        </FrameLayout>


        <!-- 비밀번호 찾기, 회원가입 -->
        <LinearLayout
            android:id="@+id/layout_login_helper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="15dp">

            <TextView
                android:id="@+id/tv_login_find_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비밀번호 찾기"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/noto_sans_kr_regular"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  |  "
                android:textSize="12sp"
                android:textColor="@color/text_line"/>

            <TextView
                android:id="@+id/tv_login_signup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회원가입"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/noto_sans_kr_regular"/>
        </LinearLayout>

        <!-- SNS 로그인 구분선 및 텍스트 -->
        <LinearLayout
            android:id="@+id/layout_login_divider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="75dp"
            app:layout_constraintTop_toBottomOf="@id/layout_login_helper"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 좌측 선 -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/text_line"
                android:layout_marginEnd="8dp"/>

            <!-- SNS 계정으로 로그인 텍스트 -->
            <TextView
                android:id="@+id/tv_login_sns_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SNS 계정으로 로그인"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="@font/noto_sans_kr_regular"
                android:includeFontPadding="false"/>

            <!-- 우측 선 -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/text_line"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- SNS 로그인 버튼 -->
        <LinearLayout
            android:id="@+id/layout_login_sns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/layout_login_divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 카카오톡 로그인 -->
            <ImageView
                android:id="@+id/iv_login_kakao"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginEnd="20dp"
                android:src="@drawable/ic_logo_kakao" />

            <!-- 네이버 로그인 -->
            <ImageView
                android:id="@+id/iv_login_naver"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_logo_naver" />

        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_login_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="26dp"
        android:layout_marginBottom="23dp"
        android:src="@drawable/ic_app_slogan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/layout_login_form" />

    <ImageView
        android:id="@+id/iv_login_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="26dp"
        android:layout_marginBottom="15dp"
        android:src="@drawable/ic_app_logo_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/iv_login_title" />

</androidx.constraintlayout.widget.ConstraintLayout>