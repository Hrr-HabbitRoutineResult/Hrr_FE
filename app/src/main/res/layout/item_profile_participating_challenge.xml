<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="15dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_width="250dp"
        android:layout_height="60dp"
        app:cardCornerRadius="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_profile_participatingChallenge"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/img_english_book"
            android:scaleType="fitCenter"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_profile_participatingChallenge_title"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:text="토익 900"
        android:textSize="15sp"
        android:fontFamily="@font/font_style"
        android:textFontWeight="500"
        android:includeFontPadding="false"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_marginTop="17dp"
        app:layout_constraintStart_toStartOf="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_marginStart="15dp"
        app:layout_constraintBottom_toBottomOf="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_marginBottom="21dp"
        android:elevation="2dp"/>
    
    <ImageView
        android:id="@+id/iv_profile_participatingChallenge_unchecked"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_check_uncertified_"
        app:layout_constraintTop_toTopOf="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_marginEnd="5dp"
        app:layout_constraintBottom_toBottomOf="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_marginBottom="10dp"
        android:elevation="2dp" />

    <ImageView
        android:id="@+id/iv_profile_participatingChallenge_checked"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_check_certified_"
        app:layout_constraintTop_toTopOf="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_marginEnd="5dp"
        app:layout_constraintBottom_toBottomOf="@+id/cv_profile_participatingChallenge_item_bg"
        android:layout_marginBottom="10dp"
        android:elevation="2dp"
        android:visibility="invisible"/>

</androidx.constraintlayout.widget.ConstraintLayout>