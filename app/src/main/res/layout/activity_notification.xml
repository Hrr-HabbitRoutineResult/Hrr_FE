<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NotificationActivity">

    <!-- 뒤로가기 버튼 -->
    <ImageView
        android:id="@+id/btn_notification_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="55dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_notification_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="알림"
        android:textSize="20sp"
        android:fontFamily="@font/noto_sans_kr_semi_bold"
        android:includeFontPadding="false"
        android:textColor="@color/text_primary"
        app:layout_constraintBottom_toBottomOf="@+id/btn_notification_back"
        app:layout_constraintTop_toTopOf="@+id/btn_notification_back"
        app:layout_constraintStart_toEndOf="@id/btn_notification_back"/>

    <!-- 선 (구분선) -->
    <View
        android:id="@+id/line_community_header"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="17dp"
        android:background="@color/grey_50"
        app:layout_constraintTop_toBottomOf="@id/tv_notification_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_notification_title"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="true"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_notification_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>
    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_notification_list_none"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_notification_title"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/iv_notification_list_none"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/img_character_grey"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_notification_list_none"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_notification_list_none"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이 기능은 향후 업데이트에서 추가될 예정입니다.\n보다 나은 서비스를 위해 준비 중이니, 조금만 기다려주세요!"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:textAlignment="center"
            android:includeFontPadding="false"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/iv_notification_list_none"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>