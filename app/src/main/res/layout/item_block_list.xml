<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
            android:id="@+id/ll_blocked_info"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="16dp"
            android:gravity="center_vertical">

        <ImageView
                android:id="@+id/iv_blocked_image"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_profile_default"
                android:layout_marginEnd="10dp"/>

        <TextView
                android:id="@+id/tv_blocked_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="김흐르"
                android:fontFamily="@font/font_style"
                android:textFontWeight="500"
                android:includeFontPadding="false"
                android:textSize="15dp"
                android:textColor="@color/text_primary"/>

        <TextView
                android:id="@+id/tv_blocked_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="실버"
                android:fontFamily="@font/font_style"
                android:textFontWeight="400"
                android:includeFontPadding="false"
                android:textSize="15dp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="6dp"/>

    </LinearLayout>

    <ImageView
            android:id="@+id/iv_blocked_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_blocked"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="22dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="12dp" />

    <ImageView
            android:id="@+id/iv_block_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_block"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="22dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="12dp"
            android:visibility="gone"/>


</androidx.constraintlayout.widget.ConstraintLayout>