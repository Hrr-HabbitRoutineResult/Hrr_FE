<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="60dp">

        <ImageView
            android:id="@+id/btn_message_chat_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="45dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="쪽지"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="@font/noto_sans_kr_semi_bold"
            android:includeFontPadding="false"
            app:layout_constraintBottom_toBottomOf="@id/btn_message_chat_back"
            app:layout_constraintStart_toEndOf="@id/btn_message_chat_back"
            app:layout_constraintTop_toTopOf="@id/btn_message_chat_back" />

        <ImageView
            android:id="@+id/btn_message_chat_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:src="@drawable/ic_message_chat_more"
            app:layout_constraintBottom_toBottomOf="@id/btn_message_chat_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_message_chat_back" />

        <!-- 회색 구분선 -->
        <View
            android:id="@+id/line_message_chatroom_1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey_50"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_message_chat_back"/>

        <!-- NestedScrollView로 감싸서 키보드 올라올 때 스크롤 가능하도록 설정 -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_message_chat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/line_message_chatroom_1"
            app:layout_constraintBottom_toTopOf="@id/et_message_chat">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_message_chat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </androidx.core.widget.NestedScrollView>

        <!-- 회색 구분선 -->
        <View
            android:id="@+id/line_message_chatroom_2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey_50"
            android:layout_marginBottom="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/scroll_message_chat"/>

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/et_message_chat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="45dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_message_search"
            android:fontFamily="@font/noto_sans_kr_regular"
            android:hint="채팅을 입력하세요"
            android:includeFontPadding="false"
            android:padding="10dp"
            android:layout_marginTop="14dp"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/scroll_message_chat"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <FrameLayout
            android:id="@+id/btn_message_chat"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintBottom_toBottomOf="@id/et_message_chat"
            app:layout_constraintEnd_toEndOf="@id/et_message_chat"
            app:layout_constraintTop_toTopOf="@id/et_message_chat">

            <!-- 버튼 배경 -->
            <ImageView
                android:id="@+id/btn_message_chat_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_message_notification" />

            <!-- 화살표 아이콘 -->
            <ImageView
                android:id="@+id/btn_message_chat_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_message_chat_arrow"
                android:layout_gravity="center"/>
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 사이드 메뉴 (햄버거 버튼 클릭 시 나오는 부분) -->
    <include
        android:id="@+id/sheet_message_bottom"
        layout="@layout/bottom_sheet_message"
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"/>
</androidx.drawerlayout.widget.DrawerLayout>
