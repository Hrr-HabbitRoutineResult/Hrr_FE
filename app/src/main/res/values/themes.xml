<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HrrAndroid" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/main_active</item>
        <item name="colorPrimaryVariant">@color/text_primary</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/sub_01</item>
        <item name="colorSecondaryVariant">@color/sub_02</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background Colors -->
        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnBackground">@color/navi_default</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>

        <!-- Letter Spacing -->
        <item name="android:letterSpacing">-0.03</item>
    </style>

    <style name="SplashTheme" parent="Base.Theme.HrrAndroid">
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <!-- Bottom Navi -->
    <style name="Theme.Navi.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/white</item>
    </style>

    <style name="Theme.HrrAndroid" parent="Base.Theme.HrrAndroid" />
</resources>